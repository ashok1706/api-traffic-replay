{
  "name": "api-replay",
  "version": "1.0.0",
  "description": "Record real API traffic, replay it anywhere, and instantly spot what changed",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "main": "./src/index.js",
  "bin": {
    "api-replay": "./src/cli/index.js"
  },
  "scripts": {

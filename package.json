  },
  "keywords": [
    "api",
    "replay",
    "record",
    "diff",
    "express",
    "middleware",
    "debugging",
    "testing"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}

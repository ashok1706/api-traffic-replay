{
  "name": "api-traffic-replay",
  "version": "1.0.2",
  "description": "Record real API traffic, replay it anywhere, and instantly spot what changed",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "api-traffic-replay": "./src/cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "api",
    "replay",
    "record",
    "diff",
    "express",
    "middleware",
    "debugging",
    "testing",
    "mock",
    "traffic",
    "http",
    "request",
    "response"
  ],
  "author": "ashok1706",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashok1706/api-traffic-replay.git"
  },
  "bugs": {
    "url": "https://github.com/ashok1706/api-traffic-replay/issues"
  },
  "homepage": "https://github.com/ashok1706/api-traffic-replay#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "10.0.3",
    "prettier": "3.8.1",
    "vitest": "^3.0.0"
  }
}
